{
  "manifest_version": 3,
  "name": "AI Buddy",
  "version": "1.4.0",
  "description": "Send selected text to an AI and ask for what it means, or read it in natural voice.",
  "permissions": [
    "contextMenus",
    "tabs",
    "storage",
    "scripting",
    "activeTab",
    "sidePanel"
  ],
   "host_permissions": [
     "https://api.openai.com/*",
     "https://openrouter.ai/*",
     "https://api.deepseek.com/*",
     "https://api.tavily.com/*",
     "https://api.search.tinyfish.ai/*",
     "https://*/*",
     "*://mail.google.com/*"
   ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "options_page": "options.html",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "open-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "Open side panel"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://mail.google.com/*"],
      "js": ["gmail-init.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "gmail-tt-policy.js",
        "vendor/jquery.min.js",
        "vendor/gmail.min.js",
        "gmail-loader.js",
        "gmail-features.js"
      ],
      "matches": ["*://mail.google.com/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
